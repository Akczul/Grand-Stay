# ============================================================
# Billing Service - Configuración de variables de entorno
# ============================================================

# Puerto donde corre el servicio
PORT=3005

# Configuración de Base de Datos MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=grand_stay_billing

# URLs de otros microservicios
RESERVATIONS_SERVICE_URL=http://localhost:3003
CONSUMPTIONS_SERVICE_URL=http://localhost:3004

# Tasa de impuesto (IVA)
TASA_IMPUESTO=0.16

# Entorno
NODE_ENV=development
