# ============================================================
# Notifications Service - Configuración de variables de entorno
# ============================================================

# Puerto donde corre el servicio
PORT=3007

# Configuración de SMTP para Nodemailer
# En desarrollo, si no se especifican credenciales, se usa Ethereal (cuenta de prueba)

# SMTP Host y puerto
SMTP_HOST=tu_smtp_host
SMTP_PORT=587

# Credenciales de SMTP
SMTP_USER=tu_usuario
SMTP_PASS=tu_contraseña

# Remitente del correo
SMTP_FROM="Grand-Stay Hotel" <noreply@grandstay.com>

# Entorno
NODE_ENV=development

# Nota: En desarrollo sin credenciales SMTP, se usará automáticamente:
# - Host: smtp.ethereal.email
# - Usuario y contraseña se generan automáticamente
# - La URL de vista previa del correo se mostrará en la consola
