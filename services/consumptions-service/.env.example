# ============================================================
# Consumptions Service - Configuración de variables de entorno
# ============================================================

# Puerto donde corre el servicio
PORT=3004

# Configuración de Base de Datos MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=grand_stay_consumptions

# URL del servicio de Reservations (para validar que reserva es "Activa")
RESERVATIONS_SERVICE_URL=http://localhost:3003

# Entorno
NODE_ENV=development
